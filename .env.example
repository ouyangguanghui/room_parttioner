# ---- RoomPartitioner 环境变量配置 ----
# 复制此文件为 .env 并按需修改

# Triton 推理服务
TRITON_URL=triton-server:8001
MODEL_NAME=room_seg
MODEL_VERSION=2
TRITON_PROTOCOL=grpc
INPUT_NAME=images
OUTPUT_NAME=output0

# 通用参数
MIN_ROOM_AREA=1.0
WALL_THRESHOLD=128
RESOLUTION=0.05

# 扩展分区
DOOR_WIDTH=20
GROW_ITERATIONS=10
MERGE_AREA_THRESHOLD=0
MERGE_RATIO_THRESHOLD=0.6
MIN_NEW_REGION_AREA=50

# 推理阈值
CONF_THRESHOLD=0.1
NMS_THRESHOLD=0.35
